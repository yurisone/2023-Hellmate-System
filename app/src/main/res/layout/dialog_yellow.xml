<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="15dp"
    android:background="@drawable/popup">
    <LinearLayout
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="vertical">
        <TextView
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:textStyle="bold"
            android:text="⚠ 다수 이상 발생 ⚠"
            android:textSize="18dp"
            android:textColor="#272424"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="248dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text1"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#272424"
            android:textSize="15dp" />

        <TextView
            android:id="@+id/text1_1"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#656363"
            android:textSize="12dp" />


        <TextView
            android:id="@+id/text2"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#272424"
            android:textSize="15dp" />

        <TextView
            android:id="@+id/text2_1"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#656363"
            android:textSize="12dp" />


        <TextView
            android:id="@+id/text3"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#272424"
            android:textSize="15dp" />

        <TextView
            android:id="@+id/text3_1"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#656363"
            android:textSize="12dp" />


        <TextView
            android:id="@+id/text4"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#272424"
            android:textSize="15dp" />

        <TextView
            android:id="@+id/text4_1"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#656363"
            android:textSize="12dp" />


        <TextView
            android:id="@+id/text5"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#272424"
            android:textSize="15dp" />

        <TextView
            android:id="@+id/text5_1"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#656363"
            android:textSize="12dp" />


        <TextView
            android:id="@+id/text6"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:text=""
            android:textColor="#272424"
            android:textSize="15dp" />

        <TextView
            android:id="@+id/text6_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#656363"
            android:textSize="12dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingTop="3dp"
        android:orientation="vertical">

        <android.widget.Button
            android:id="@+id/ok_btn"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:background="@drawable/round_button3"
            android:text="확인"
            android:textColor="#FFFFFF"
            android:textSize="23dp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>